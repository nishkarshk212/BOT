# Telegram credentials
BOT_TOKEN=

# Pyrogram requires a Telegram APP id/hash (not the bot token).
# Create one free at https://my.telegram.org -> "API development tools".
# These are app credentials, safe to use across bots.
API_ID=
API_HASH=

# --- LLM backend ---
# Option A: OpenRouter (cloud). Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
MODEL=meta-llama/llama-3.3-70b-instruct:free
FALLBACK_MODELS=google/gemma-2-9b-it:free,meta-llama/llama-3.1-8b-instruct:free,nousresearch/hermes-3-llama-3.1-8b:free

# Option B: local Ollama (no key, private). Install ollama, run `ollama pull dolphin-llama3`,
# then set LLM_BASE_URL to the OpenAI-compatible endpoint and MODEL to the local model:
# LLM_BASE_URL=http://localhost:11434/v1
# MODEL=dolphin-llama3
# OPENROUTER_API_KEY=   (leave blank to use the local backend)
LLM_BASE_URL=https://openrouter.ai/api/v1

# Tuning
MAX_HISTORY=18
REQUEST_TIMEOUT=25
DB_PATH=nova.db
DATA_DIR=data
