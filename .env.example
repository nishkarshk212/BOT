BOT_TOKEN=

# Optional: enable the LLM brain (leave blank to use the built-in rule-based responder).
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
MODEL=meta-llama/llama-3.3-70b-instruct:free
FALLBACK_MODELS=google/gemma-2-9b-it:free,meta-llama/llama-3.1-8b-instruct:free,nousresearch/hermes-3-llama-3.1-8b:free

# Tuning
MAX_HISTORY=18
REQUEST_TIMEOUT=25
DB_PATH=nova.db
DATA_DIR=data
